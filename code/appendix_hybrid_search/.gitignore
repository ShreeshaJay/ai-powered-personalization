# Cached indexes (large, regenerable from scripts)
cache/
*.npy
*.npz

# Evaluation outputs (large plots and raw data excluded, key results kept)
outputs/plots/
!outputs/metrics/
!outputs/metrics/*.json
!outputs/metrics/*.csv

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
recsys_venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# LLM labeling artifacts (not part of this appendix)
*labeling*.json
*disagreements*.json
*disagreements*.txt
